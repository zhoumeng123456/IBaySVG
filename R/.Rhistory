tun_spl1 <- function(spelist, calpha.list, g = 1, result) {
## test length
n1 <- length(spelist)
n2 <- length(calpha.list)
if (n1 != n2) {
warning("the length of expression matrix do not match the calpha's")
}
tunning_choose <- integer(n1)  # 使用integer更高效
# 预分配常用变量
spline_levels <- 1:4
for (iii in seq_len(n1)) {
y <- spelist[[iii]][[1]][, g]  # 移除unname，可能不需要
zero_count <- sum(y == 0)
samplenum <- length(y)
zero_ratio <- zero_count / samplenum
cat("Gene", iii, "zero ratio:", zero_ratio, "\n")
if (zero_ratio > 0.9) {
tunning_choose[iii] <- 1L
next  # 提前退出当前迭代
}
# 预先获取celltype数量
celltypenum <- ncol(calpha.list[[iii]])
# 预处理calpha矩阵（只做一次）
calpha_processed <- calpha.list[[iii]]
rows_with_sum_1 <- rowSums(calpha_processed) == 1
calpha_processed[rows_with_sum_1, 1] <- calpha_processed[rows_with_sum_1, 1] - 0.01
calpha_processed[calpha_processed < 0] <- 0
aic_value <- numeric(4)
model_type <- if (zero_ratio < 0.7 && samplenum > 500) "zeroinfl" else "hurdle"
for (kkk in spline_levels) {
x <- result[[2]][[kkk]][[iii]]
# 更高效的数据框创建
data <- data.frame(
x = x,
calpha_processed,  # 直接使用处理后的矩阵
y = y,
check.names = FALSE
)
# 构建列名（避免重复创建）
x_names <- paste0("x", seq_len(2 * kkk))
calpha_names <- paste0("calpha", seq_len(celltypenum))
names(data) <- c(x_names, calpha_names, "y")
# 构建公式
predictor_names <- names(data)[-ncol(data)]  # 排除y列
formula_str <- paste(predictor_names, collapse = " + ")
formula_full <- as.formula(paste("y ~", formula_str, "|", formula_str))
# 拟合模型
if (model_type == "zeroinfl") {
model_zinb <- zeroinfl(formula_full, data = data, dist = "negbin")
} else {
model_zinb <- hurdle(formula_full, data = data, dist = "negbin")
}
aic_value[kkk] <- AIC(model_zinb)
}
tunning_choose[iii] <- which.min(aic_value)
}
tunning_final <- max(tunning_choose)
cat("Choosing b-spline degree:", tunning_final, "\n")
return(tunning_final)
}
begin <- Sys.time()
tun_choose <- tun_spl1(spelist = spelist,calpha.list = c_alpha,g=g,result= result)
end<-Sys.time()
time_value=as.numeric((end-begin), units = "mins")
print(time_value)
