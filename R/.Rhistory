aic_value <- numeric(4)
model_type <- if (zero_ratio < 0.7 && samplenum > 500) "zeroinfl" else "hurdle"
for (kkk in spline_levels) {
x <- result[[2]][[kkk]][[iii]]
# 更高效的数据框创建
data <- data.frame(
x = x,
calpha_processed,  # 直接使用处理后的矩阵
y = y,
check.names = FALSE
)
# 构建列名（避免重复创建）
x_names <- paste0("x", seq_len(2 * kkk))
calpha_names <- paste0("calpha", seq_len(celltypenum))
names(data) <- c(x_names, calpha_names, "y")
# 构建公式
predictor_names <- names(data)[-ncol(data)]  # 排除y列
formula_str <- paste(predictor_names, collapse = " + ")
formula_full <- as.formula(paste("y ~", formula_str, "|", formula_str))
# 拟合模型
if (model_type == "zeroinfl") {
model_zinb <- zeroinfl(formula_full, data = data, dist = "negbin")
} else {
model_zinb <- hurdle(formula_full, data = data, dist = "negbin")
}
aic_value[kkk] <- AIC(model_zinb)
}
tunning_choose[iii] <- which.min(aic_value)
}
tunning_final <- max(tunning_choose)
cat("Choosing b-spline degree:", tunning_final, "\n")
return(tunning_final)
}
